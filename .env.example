# Локально: cp .env.example .env, заполни, затем: set -a; source .env; set +a
# На bothost.ru: эти же значения задай в разделе Environment (секреты НЕ коммить).

# --- Telegram-бот ---
# Токен бота от @BotFather
BOT_TOKEN=
# Твой user_id (узнать у @userinfobot). Без него бот слушает всех — задай!
ADMIN_ID=

# --- MRKT ---
# Первичный токен из DevTools (потом можно обновлять командой /settoken в боте)
MRKT_TOKEN=
# Прокси для api.tgmrkt.io. Хост в Нидерландах (EU-IP) — прокси НЕ нужен,
# оставь пустым. Заполняй только если появятся 403/геоблок. Пример:
# MRKT_PROXY=socks5://user:pass@ip-vps:1080
MRKT_PROXY=

# --- Настройки сканера (можно менять и из бота) ---
# Ликвидные коллекции с высоким объёмом (там чаще транзиентные недооценки).
# Floor 3-35 TON. НЕ бери floor-спам (Xmas Stocking: все по 2.46, спред 0)
# и премиум (Plush Pepe ~5500 TON). Менять можно из бота: /watch, /unwatch.
MRKT_COLLECTIONS=Mood Pack,Swiss Watch,Bonded Ring
MRKT_MARGIN=0.04
MRKT_FLOOR_RANK=3
# Комиссия продавца ДИНАМИЧЕСКАЯ (промо). Сейчас 0% (проверено в приложении).
# Если MRKT вернёт комиссию — посмотри её при листинге и впиши сюда.
MRKT_FEE=0
MRKT_POLL=12
